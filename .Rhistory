library(readxl)
library(dplyr)
library(purrr)
library(broom)
dta <- read_excel("ClassActivity_week6Data-1.xlsx")
file_path <- "ClassActivity_week6Data-1.xlsx"
# Get all sheet names
sheet_names <- excel_sheets(file_path)
# Read all sheets
data_list <- lapply(sheet_names, function(s) {
read_excel(file_path, sheet = s)
})
names(data_list) <- sheet_names
# Analysis function (assumes 2 numeric columns per sheet)
analyze_sheet <- function(df) {
df <- df %>% select(where(is.numeric))
x <- df[[1]]
y <- df[[2]]
model <- lm(y ~ x)
data.frame(
Mean_X = mean(x, na.rm = TRUE),
Mean_Y = mean(y, na.rm = TRUE),
Var_X = var(x, na.rm = TRUE),
Var_Y = var(y, na.rm = TRUE),
SD_X = sd(x, na.rm = TRUE),
SD_Y = sd(y, na.rm = TRUE),
Correlation = cor(x, y, use = "complete.obs"),
R_squared = summary(model)$r.squared,
Regression = paste0("y = ",
round(coef(model)[1], 4),
" + ",
round(coef(model)[2], 4),
"x")
)
}
# Apply to all sheets
results <- bind_rows(
lapply(names(data_list), function(name) {
res <- analyze_sheet(data_list[[name]])
res$Sheet <- name
res
})
)
# Final table
results <- results %>% select(Sheet, everything())
print(results)
