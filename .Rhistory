library(ggplot2)
file_path <- "ClassActivity_week6Data-1.xlsx"
# Read and combine all sheets safely
data_all <- lapply(excel_sheets(file_path), function(s) {
df <- read_excel(file_path, sheet = s)
# keep only numeric columns
df <- df %>% select(where(is.numeric))
# IMPORTANT: explicitly rename columns
names(df)[1:2] <- c("X", "Y")
df$Sheet <- s
df
}) %>% bind_rows()
# Plot
ggplot(data_all, aes(x = X, y = Y)) +
geom_point() +
geom_smooth(method = "lm", se = FALSE) +
facet_wrap(~Sheet, scales = "free") +
labs(title = "All 4 Datasets",
x = "X",
y = "Y") +
theme_minimal()
