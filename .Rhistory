library(readxl)
library(dplyr)
library(purrr)
library(broom)
# Dataset A
A <- data.frame(
X = c(10,8,13,9,11,14,6,4,12,7,5),
Y = c(8.04,6.95,7.58,8.81,8.33,9.96,7.24,4.26,10.84,4.82,5.68),
Sheet = "DatasetA"
)
# Dataset B
B <- data.frame(
X = c(10,8,13,9,11,14,6,4,12,7,5),
Y = c(9.14,8.14,8.74,8.77,9.26,8.1,6.13,3.1,9.13,7.26,4.74),
Sheet = "DatasetB"
)
# Dataset C
C <- data.frame(
X = c(10,8,13,9,11,14,6,4,12,7,5),
Y = c(7.46,6.77,12.74,7.11,7.81,8.84,6.08,5.39,8.15,6.42,5.73),
Sheet = "DatasetC"
)
# Dataset D
D <- data.frame(
X = c(8,8,8,8,8,8,8,19,8,8,8),
Y = c(6.58,5.76,7.71,8.84,8.47,7.04,5.25,12.5,5.56,7.91,6.89),
Sheet = "DatasetD"
)
# Combine
data_all <- bind_rows(A, B, C, D)
analyze_sheet <- function(df) {
model <- lm(Y ~ X, data = df)
data.frame(
Mean_X = mean(df$X),
Mean_Y = mean(df$Y),
Var_X = var(df$X),
Var_Y = var(df$Y),
SD_X = sd(df$X),
SD_Y = sd(df$Y),
Correlation = cor(df$X, df$Y),
R_squared = summary(model)$r.squared,
Regression = paste0("y = ",
round(coef(model)[1], 4),
" + ",
round(coef(model)[2], 4), "x")
)
}
results <- data_all %>%
group_by(Sheet) %>%
group_modify(~ analyze_sheet(.x)) %>%
ungroup()
print(results)
ggplot(data_all, aes(x = X, y = Y)) +
geom_point() +
geom_smooth(method = "lm", se = FALSE) +
facet_wrap(~Sheet) +
labs(title = "Anscombe's Quartet",
x = "X",
y = "Y") +
theme_minimal()
