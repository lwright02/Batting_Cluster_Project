cdc = read.table("https://www.stat.uchicago.edu/~yibi/s220/labs/data/cdc.dat", h=T)
cdc$BMIrange = cut(cdc$bmi, breaks=c(0, 18.5, 25, 30, Inf), right=FALSE)
cdc$bmi = with(cdc, 703.7*weight/height^2)
cdc$BMIrange = cut(cdc$bmi, breaks=c(0, 18.5, 25, 30, Inf), right=FALSE)
cdc$BMIrange = factor(cdc$BMIrange,
labels=c("Underweight", "Healthy", "Overweight", "Obese"))
xtabs(~BMIrange, data=cdc)
xtabs(~ genhlth + BMIrange, data=cdc)
addmargins(xtabs(~ genhlth + BMIrange, data=cdc))
ggplot(cdc, aes(x=genhlth, fill=BMIrange)) + geom_bar() +
labs(x="Self-Rated General Health", fill="BMI Range")
ggplot(cdc, aes(x=genhlth, fill=BMIrange)) + geom_bar(position="fill") +
labs(x="Self-Rated General Health", fill="BMI Range")
